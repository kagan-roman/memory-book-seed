{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(python3 build/*.py)",
      "Bash(python3 build/*.py:*)",
      "Bash(npx vivliostyle build:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(pdfinfo:*)",
      "Bash(pdftotext:*)",
      "Bash(pdftoppm:*)",
      "Bash(pdfimages:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(rm:*)"
    ]
  },
  "enableAllProjectMcpServers": true
}
