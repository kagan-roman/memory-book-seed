# ── Сгенерированное (не коммитим) ────────────────────────────────────────────
build/.out/                 # промежуточный рендер карт/деревьев/manuscript.html
build/node_modules/         # @vivliostyle/cli
assets/geo/*.geojson        # скачивается build/clip_geo.py (см. README)
assets/geo/_src/            # исходный Natural Earth (большой, скачивается)

# ── Тяжёлые исходники пользователя (по желанию — раскомментируйте) ────────────
# sources/*.pdf             # сканы родословной — личные; не публиковать без согласия
# assets/portraits/         # лица людей — персональные данные

# ── Системное ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.DS_Store
.venv/
node_modules/

# ── Финал ─────────────────────────────────────────────────────────────────────
# dist/book.pdf — итог; коммитить или нет, решаете вы (может содержать перс. данные).
