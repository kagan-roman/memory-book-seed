# ── Сгенерированное (не коммитим) ────────────────────────────────────────────
# (комментарии gitignore — только на отдельной строке, не в конце паттерна)

# промежуточный рендер карт/деревьев/manuscript.html
build/.out/
# вычитанная копия PDF от рецензента (рабочий вход стадии /proof; может быть
# тяжёлой и личной). PROOF-*.md — наоборот, история правок, коммитится.
dist/book.annotated.pdf
# @vivliostyle/cli
build/node_modules/
# скачивается build/clip_geo.py (см. README)
assets/geo/*.geojson
# исходный Natural Earth (большой, скачивается)
assets/geo/_src/

# ── Тяжёлые исходники пользователя (по желанию — раскомментируйте) ────────────
# сканы родословной — личные; не публиковать без согласия:
# sources/*.pdf
# лица людей — персональные данные:
# assets/portraits/
# сканы архивных документов ЦАМО — первоисточник, тяжёлые; держать локально,
# если не нужны в репо (.gitkeep оставляйте, чтобы папка существовала):
# assets/documents/

# ── Системное ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.DS_Store
.venv/
node_modules/

# ── Финал ─────────────────────────────────────────────────────────────────────
# dist/book.pdf — итог; коммитить или нет, решаете вы (может содержать
# персональные данные).
